{
  "name": "larena/licensing",
  "description": "Runtime licensing layer that decides which package, bundle and capability features are available to a site, with signed entitlement snapshots, trial restrictions, subscription/expiration policies, environment-aware licenses, limits and explainable locks.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rim Zabarov",
      "homepage": "https://github.com/zabarov"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "scripts": {
    "test": "@php -r \"echo 'No runtime tests in enforcement baseline.'.PHP_EOL;\"",
    "test:unit": "@test",
    "lint": "@php -r \"echo 'No lint targets in enforcement baseline.'.PHP_EOL;\"",
    "analyse": "@php -r \"echo 'No static analysis targets in enforcement baseline.'.PHP_EOL;\"",
    "validate:larena": "test -f .larena/spec-ref.json && test -f .larena/launch-context.json",
    "evidence:check": "test -f docs/project-management/evidence/runtime-security/batch-0/licensing-repository-transition/README.md && test -f docs/project-management/evidence/runtime-security/batch-0/licensing-repository-transition/file-map.json && test -f docs/project-management/evidence/runtime-security/batch-0/licensing-repository-transition/graph-sync-proposal.json && test -f docs/project-management/evidence/runtime-security/batch-0/licensing-repository-transition/independent-review.md"
  },
  "minimum-stability": "stable"
}
