#!/usr/bin/env sh
set -eu
COMPOSER_BIN="${COMPOSER_BIN:-}"
if [ -z "$COMPOSER_BIN" ] && [ -x /Applications/ServBay/package/bin/composer ]; then
  COMPOSER_BIN=/Applications/ServBay/package/bin/composer
fi
if [ -z "$COMPOSER_BIN" ] && command -v composer >/dev/null 2>&1; then
  COMPOSER_BIN="$(command -v composer)"
fi
if [ -n "$COMPOSER_BIN" ]; then
  PATH="/opt/homebrew/opt/php@8.3/bin:$PATH" "$COMPOSER_BIN" run quality:gate
else
  echo "composer is required for Larena package pre-push gate" >&2
  exit 1
fi
